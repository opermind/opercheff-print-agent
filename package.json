{
  "name": "opercheff-print-agent",
  "version": "0.1.0",
  "description": "Agente de impressão Windows para OperChef360",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "pkg . --targets node20-win-x64 --output dist/OperChefPrintAgent.exe"
  },
  "pkg": {
    "assets": ["assets/**/*"],
    "targets": ["node20-win-x64"],
    "outputPath": "dist"
  },
  "dependencies": {
    "express": "^4.19.2",
    "node-thermal-printer": "^4.4.5",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "better-sqlite3": "^11.3.0",
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
